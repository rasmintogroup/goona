{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "goona",
  "compatibility_date": "2026-05-13",
  "main": "worker.js", // TAMBAHKAN INI: Memberitahu Cloudflare ini file utamanya
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS" 
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
